# Chave da API OpenAI (obrigatória para o chat com IA)
OPENAI_API_KEY=sk-sua-chave-aqui

# Modelo OpenAI (opcional — padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Senha do painel administrativo
ADMIN_PASSWORD=sua-senha-segura

# Porta do servidor (opcional — padrão: 3001)
PORT=3001

# Origens permitidas (CORS), separadas por vírgula
# Em produção, use o domínio do site: https://www.novaeraveiculosbm.com.br
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:5500,https://www.novaeraveiculosbm.com.br,https://novaeraveiculosbm.com.br
